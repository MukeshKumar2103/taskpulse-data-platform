{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist",
    "rootDir": "./",

    "baseUrl": ".",

    "paths": {
      "@shared/*": ["apps/api/src/shared/*"],
      "@clean-db/*": ["databases/clean-db/*"],
      "@raw-db/*": ["databases/raw-db/*"],
      "@analytics-db/*": ["databases/analytics-db/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}